// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  name  String
  scores Scores[]
  currentGame Game? 
  
}

model Scores{
  id  Int @id @default(autoincrement())
  userScores User @relation(fields:[userId], references:[id], onDelete: Cascade)
  userId Int
  value Int
  image Image @relation(fields: [imageId],references: [id])
  imageId Int
}

model Game {
  id  Int @id @default(autoincrement())
  start   DateTime @default(now())
  player User @relation(fields:[userId],references: [id])
  userId Int @unique
  imageLoaded ImageLoaded?
  //finished Boolean @default(false)
}
model Image {
  id  Int @id @default(autoincrement())
  //currentGames Game[] @relation(fields:[gameId],references: [id])
  name String
  fileName  String @unique
  characters Character[]
  userScores Scores[]

}

model Character{
  id  Int @id @default(autoincrement())
  currentImage Image @relation(fields:[imageId], references:[id])
  imageId Int 
  name String
  positionX Int
  positionY Int
}

model ImageLoaded {
  id  Int @id @default(autoincrement())
  currentGames Game @relation(fields:[gameId],references: [id],onDelete: Cascade)
  gameId Int @unique
  name String
  fileName String
  characters CharacterLoaded[] 
}



model CharacterLoaded{
   id  Int @id @default(autoincrement())
  currentImageLoaded ImageLoaded @relation(fields:[imageId], references:[id],onDelete: Cascade)
  imageId Int
  name String
  positionX Int
  positionY Int
  finded Boolean @default(false)

}
